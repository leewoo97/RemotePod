<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            prefWidth="1280" prefHeight="820"
            style="-fx-background-color: #ffffff; -fx-font-family: 'Segoe UI', 'Inter', Arial;">

    <left>
        <VBox prefWidth="224" minWidth="224" maxWidth="224"
              style="-fx-background-color: #eef2f6; -fx-border-color: transparent #dce3ec transparent transparent; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="56" right="15" bottom="18" left="15"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Pane prefWidth="34" prefHeight="34">
                    <SVGPath content="M5 17 L14 4 L20 4 L11 17 L20 30 L14 30 Z"
                             fill="#9b5cf6"/>
                    <SVGPath content="M18 17 L27 4 L33 4 L24 17 L33 30 L27 30 Z"
                             fill="#a855f7"/>
                </Pane>
                <Label text="DevPod"
                       style="-fx-text-fill: #090b12; -fx-font-size: 25px; -fx-font-weight: 800;"/>
            </HBox>

            <Region prefHeight="48"/>

            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="11" prefHeight="40"
                      style="-fx-background-color: #b35ff2; -fx-background-radius: 5;">
                    <padding>
                        <Insets left="18" right="14"/>
                    </padding>
                    <Label text="▣" style="-fx-text-fill: white; -fx-font-size: 15px;"/>
                    <Label text="Workspaces" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="11" prefHeight="40">
                    <padding>
                        <Insets left="18" right="14"/>
                    </padding>
                    <Label text="▰" style="-fx-text-fill: #535a67; -fx-font-size: 15px;"/>
                    <Label text="Providers" style="-fx-text-fill: #535a67; -fx-font-size: 15px;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="11" prefHeight="40">
                    <padding>
                        <Insets left="18" right="14"/>
                    </padding>
                    <Label text="⚙" style="-fx-text-fill: #535a67; -fx-font-size: 15px;"/>
                    <Label text="Settings" style="-fx-text-fill: #535a67; -fx-font-size: 15px;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <padding>
                    <Insets left="16"/>
                </padding>
                <Label text="Open sourced by" style="-fx-text-fill: #78859a; -fx-font-size: 13px;"/>
                <Label text="loft" style="-fx-text-fill: #65b7f6; -fx-font-size: 23px; -fx-font-weight: 800;"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <BorderPane style="-fx-background-color: #ffffff;">
            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="106"
                      style="-fx-background-color: #ffffff; -fx-border-color: transparent transparent #dce3ec transparent; -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets left="16" right="11"/>
                    </padding>

                    <Label text="Workspaces"
                           style="-fx-text-fill: #111827; -fx-font-size: 17px; -fx-font-weight: 800;"/>

                    <Button text="+   Create" focusTraversable="false"
                            style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 16 9 16; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700;">
                        <HBox.margin>
                            <Insets left="9"/>
                        </HBox.margin>
                    </Button>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="●" style="-fx-text-fill: #111827; -fx-font-size: 17px;">
                        <HBox.margin>
                            <Insets right="26"/>
                        </HBox.margin>
                    </Label>

                    <Button focusTraversable="false"
                            style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 13 8 13;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="12">
                                <Label text=".PRO"
                                       style="-fx-background-color: #161b26; -fx-background-radius: 2; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: 900; -fx-padding: 2 5 2 5;"/>
                                <Label text="Try DevPod Pro"
                                       style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </top>

            <center>
                <VBox style="-fx-background-color: #ffffff;">
                    <padding>
                        <Insets top="35" right="26" bottom="0" left="31"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <CheckBox text="Select all" focusTraversable="false"
                                  style="-fx-text-fill: #697386; -fx-font-size: 15px; -fx-font-weight: 700;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox spacing="9" alignment="CENTER_RIGHT">
                            <Button text="▰  Providers (2/2)" focusTraversable="false"
                                    style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 14 9 14; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                            <Button text="●  Status (4/4)" focusTraversable="false"
                                    style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 14 9 14; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                            <Button text="Sort by: Recently Used  ⌄" focusTraversable="false"
                                    style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 15 9 15; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                        </HBox>
                    </HBox>

                    <StackPane VBox.vgrow="ALWAYS">
                        <VBox alignment="TOP_CENTER" spacing="13">
                            <StackPane.margin>
                                <Insets top="38"/>
                            </StackPane.margin>
                            <Label text="No workspaces for selection found. Click here to create one"
                                   style="-fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 400;"/>
                            <Button text="Create Workspace" focusTraversable="false"
                                    style="-fx-background-color: #eef1f5; -fx-background-radius: 5; -fx-padding: 9 14 9 14; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                        </VBox>
                    </StackPane>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER_LEFT" prefHeight="30"
                      style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                    <padding>
                        <Insets left="24" right="24"/>
                    </padding>

                    <Label text="0.6.15  windows  x86_64"
                           style="-fx-text-fill: #4b5563; -fx-font-size: 13px;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER_RIGHT" spacing="24">
                        <Label text="⌕" style="-fx-text-fill: #111827; -fx-font-size: 20px;"/>
                        <Label text="★" style="-fx-text-fill: #111827; -fx-font-size: 16px;"/>
                        <Label text="▣" style="-fx-text-fill: #111827; -fx-font-size: 15px;"/>
                        <Label text="✸" style="-fx-text-fill: #111827; -fx-font-size: 16px;"/>
                    </HBox>
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
