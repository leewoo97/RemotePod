<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sshmanager.MainController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #1e1e2e;">

    <!-- 상단 타이틀 바 -->
    <top>
        <HBox style="-fx-background-color: #181825; -fx-padding: 12 16; -fx-alignment: center-left; -fx-spacing: 10;">
            <Label text="🖥  SSH Manager"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- 연결 상태 표시 -->
            <Circle fx:id="statusCircle" radius="7" fill="red"/>
            <Label fx:id="statusLabel" text="연결 안 됨"
                   style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.32" style="-fx-background-color: #1e1e2e;">

            <!-- ── 왼쪽: 서버 관리 패널 ── -->
            <VBox spacing="8" style="-fx-padding: 12; -fx-background-color: #181825;">

                <Label text="서버 목록" style="-fx-font-weight: bold; -fx-text-fill: #89b4fa; -fx-font-size: 13px;"/>

                <ListView fx:id="serverListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #1e1e2e; -fx-border-color: #313244; -fx-border-radius: 4;"/>

                <HBox spacing="6">
                    <Button text="삭제" onAction="#handleRemoveServer" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 4;"/>
                </HBox>

                <Separator style="-fx-background-color: #313244;"/>

                <Label text="서버 추가" style="-fx-font-weight: bold; -fx-text-fill: #89b4fa; -fx-font-size: 13px;"/>

                <GridPane hgap="8" vgap="6">
                    <Label text="이름" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                    <TextField fx:id="nameField" promptText="내 서버"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #585b70; -fx-background-radius: 4;"/>

                    <Label text="호스트" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                    <TextField fx:id="hostField" promptText="192.168.0.1"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #585b70; -fx-background-radius: 4;"/>

                    <Label text="포트" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                    <TextField fx:id="portField" promptText="22"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #585b70; -fx-background-radius: 4;"/>

                    <Label text="사용자" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                    <TextField fx:id="userField" promptText="ubuntu"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #585b70; -fx-background-radius: 4;"/>

                    <Label text="비밀번호" GridPane.columnIndex="0" GridPane.rowIndex="4"
                           style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"
                                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #585b70; -fx-background-radius: 4;"/>

                    <columnConstraints>
                        <ColumnConstraints minWidth="55"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                </GridPane>

                <Button text="＋ 서버 추가" onAction="#handleAddServer" maxWidth="Infinity"
                        style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 4;"/>

                <HBox spacing="6">
                    <Button text="🔗 접속" onAction="#handleConnect" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 4;"/>
                    <Button text="✕ 해제" onAction="#handleDisconnect" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #585b70; -fx-text-fill: #cdd6f4; -fx-font-weight: bold; -fx-background-radius: 4;"/>
                </HBox>
            </VBox>

            <!-- ── 오른쪽: 명령 실행 패널 ── -->
            <VBox spacing="8" style="-fx-padding: 12; -fx-background-color: #1e1e2e;">

                <!-- 즐겨찾기 명령어 -->
                <HBox spacing="8" style="-fx-alignment: center-left;">
                    <Label text="빠른 명령" style="-fx-text-fill: #89b4fa; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="quickCommandBox" promptText="자주 쓰는 명령어 선택..." HBox.hgrow="ALWAYS" maxWidth="Infinity"
                              style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>
                </HBox>

                <!-- 명령어 입력 -->
                <HBox spacing="8">
                    <Label text="\$" style="-fx-text-fill: #a6e3a1; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 4 0 0 0;"/>
                    <TextField fx:id="commandField" promptText="명령어를 입력하세요 (Enter로 실행)"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #585b70;
                                      -fx-font-family: 'Consolas'; -fx-font-size: 13px; -fx-background-radius: 4;"/>
                    <Button text="실행" onAction="#handleExecute"
                            style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 4; -fx-min-width: 50;"/>
                </HBox>

                <!-- 출력 영역 -->
                <HBox spacing="8" style="-fx-alignment: center-left;">
                    <Label text="출력 결과" style="-fx-text-fill: #89b4fa; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="초기화" onAction="#handleClearOutput"
                            style="-fx-background-color: #313244; -fx-text-fill: #a6adc8; -fx-background-radius: 4; -fx-font-size: 11px;"/>
                </HBox>

                <TextArea fx:id="outputArea" VBox.vgrow="ALWAYS" editable="false" wrapText="true"
                          style="-fx-background-color: #11111b; -fx-text-fill: #cdd6f4;
                                 -fx-font-family: 'Consolas'; -fx-font-size: 12px;
                                 -fx-border-color: #313244; -fx-border-radius: 4; -fx-background-radius: 4;"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
