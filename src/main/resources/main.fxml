<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sshmanager.DevPodController"
           prefWidth="1280" prefHeight="820"
           style="-fx-background-color: #ffffff; -fx-font-family: 'Segoe UI', 'Inter', Arial;">
    <BorderPane>
        <left>
            <VBox prefWidth="196" minWidth="196" maxWidth="196"
                  style="-fx-background-color: #eef2f6; -fx-border-color: transparent #dce3ec transparent transparent; -fx-border-width: 0 1 0 0;">
                <padding><Insets top="48" right="10" bottom="14" left="10"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="10" translateX="13" translateY="-30">
                    <ImageView fitWidth="300" fitHeight="150" preserveRatio="true">
                        <image><Image url="@images/logo/remotepod_main.png"/></image>
                    </ImageView>
                </HBox>

                <Region prefHeight="36"/>

                <VBox spacing="10">
                    <HBox fx:id="workspacesNav" alignment="CENTER_LEFT" spacing="9" prefHeight="34"
                          onMouseClicked="#showWorkspaces"
                          style="-fx-background-color: #b35ff2; -fx-background-radius: 5; -fx-cursor: hand;">
                        <padding><Insets left="13" right="10"/></padding>
                        <ImageView fitWidth="17" fitHeight="17" preserveRatio="true" translateY="1">
                            <image><Image url="@images/png-white-fixed/Briefcase.png"/></image>
                        </ImageView>
                        <Label text="Workspaces" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 500;"/>
                    </HBox>

                    <HBox fx:id="serversNav" alignment="CENTER_LEFT" spacing="9" prefHeight="34"
                          onMouseClicked="#showServers" style="-fx-cursor: hand;">
                        <padding><Insets left="13" right="10"/></padding>
                        <ImageView fitWidth="15" fitHeight="15" preserveRatio="true">
                            <image><Image url="@images/png-fixed/Stack3D.png"/></image>
                        </ImageView>
                        <Label fx:id="serversNavLabel" text="Servers"
                               style="-fx-text-fill: #535a67; -fx-font-size: 13px;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="9" prefHeight="34">
                        <padding><Insets left="13" right="10"/></padding>
                        <ImageView fitWidth="15" fitHeight="15" preserveRatio="true">
                            <image><Image url="@images/png-fixed/Cog.png"/></image>
                        </ImageView>
                        <Label text="Settings" style="-fx-text-fill: #535a67; -fx-font-size: 13px;"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets left="16"/></padding>
                    <Label text="Developed by" style="-fx-text-fill: #78859a; -fx-font-size: 12px;"/>
                    <Label text="leewoo97" style="-fx-text-fill: #535a67; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                </HBox>
            </VBox>
        </left>

        <center>
            <BorderPane style="-fx-background-color: #ffffff;">
                <top>
                    <HBox alignment="CENTER_LEFT" prefHeight="88"
                          style="-fx-background-color: #ffffff; -fx-border-color: transparent transparent #dce3ec transparent; -fx-border-width: 0 0 1 0;">
                        <padding><Insets left="12" right="9"/></padding>

                        <Label fx:id="backButton" onMouseClicked="#goBack" visible="false" managed="false"
                               style="-fx-cursor: hand;">
                            <graphic>
                                <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                    <image><Image url="@images/png-fixed/ArrowLeft.png"/></image>
                                </ImageView>
                            </graphic>
                            <HBox.margin><Insets right="16"/></HBox.margin>
                        </Label>

                        <Label fx:id="titleLabel" text="Workspaces"
                               style="-fx-text-fill: #111827; -fx-font-size: 15px; -fx-font-weight: 700;"/>

                        <Button fx:id="headerCreateButton" text="Create" onAction="#showCreateWorkspace" focusTraversable="false"
                                style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 11; -fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 600;">
                            <graphic>
                                <ImageView fitWidth="12" fitHeight="12" preserveRatio="true">
                                    <image><Image url="@images/png-fixed/Plus.png"/></image>
                                </ImageView>
                            </graphic>
                            <HBox.margin><Insets left="9"/></HBox.margin>
                        </Button>

                        <Button fx:id="cancelWorkspaceButton" text="Cancel" onAction="#cancelWorkspaceCreation"
                                visible="false" managed="false" focusTraversable="false"
                                style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 11; -fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 600;">
                            <HBox.margin><Insets left="14"/></HBox.margin>
                        </Button>

                        <Region HBox.hgrow="ALWAYS"/>

                        <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                            <image><Image url="@images/png-fixed/Bell.png"/></image>
                            <HBox.margin><Insets right="26"/></HBox.margin>
                        </ImageView>

                        <Button focusTraversable="false"
                                style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10;">
                            <graphic>
                                <HBox alignment="CENTER" spacing="12">
                                    <ImageView fitWidth="35" fitHeight="18" preserveRatio="true">
                                        <image><Image url="@images/png-fixed/DevPodProBadge.png"/></image>
                                    </ImageView>
                                    <Label text="Try RemotePod Pro"
                                           style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                                </HBox>
                            </graphic>
                        </Button>
                    </HBox>
                </top>

                <center>
                    <StackPane>
                        <fx:include fx:id="workspaceView" source="views/workspaces.fxml"/>
                        <fx:include fx:id="serversView" source="views/servers.fxml"
                                    visible="false" managed="false"/>
                        <fx:include fx:id="createSection" source="views/create-workspace.fxml"
                                    visible="false" managed="false"/>
                    </StackPane>
                </center>

                <bottom>
                    <HBox alignment="CENTER_LEFT" prefHeight="28"
                          style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                        <padding><Insets left="24" right="24"/></padding>
                        <Label text="1.0.0  windows  x86_64"
                               style="-fx-text-fill: #4b5563; -fx-font-size: 12px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER_RIGHT" spacing="20">
                            <ImageView fitWidth="16" fitHeight="16" preserveRatio="true"><image><Image url="@images/png-fixed/Search.png"/></image></ImageView>
                            <ImageView fitWidth="16" fitHeight="16" preserveRatio="true"><image><Image url="@images/png-fixed/Gold.png"/></image></ImageView>
                            <ImageView fitWidth="16" fitHeight="16" preserveRatio="true"><image><Image url="@images/png-fixed/File.png"/></image></ImageView>
                            <ImageView fitWidth="16" fitHeight="16" preserveRatio="true"><image><Image url="@images/png-fixed/Cog.png"/></image></ImageView>
                        </HBox>
                    </HBox>
                </bottom>
            </BorderPane>
        </center>
    </BorderPane>

    <fx:include fx:id="newServerModal" source="views/new-server-modal.fxml"
                visible="false" managed="false"/>
    <fx:include fx:id="workspaceActionModal" source="views/workspace-action-modal.fxml"
                visible="false" managed="false"/>
</StackPane>
