<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sshmanager.DevPodController"
            prefWidth="1280" prefHeight="820"
            style="-fx-background-color: #ffffff; -fx-font-family: 'Segoe UI', 'Inter', Arial;">

    <left>
        <VBox prefWidth="224" minWidth="224" maxWidth="224"
              style="-fx-background-color: #eef2f6; -fx-border-color: transparent #dce3ec transparent transparent; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="56" right="15" bottom="18" left="15"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Pane prefWidth="34" prefHeight="34">
                    <SVGPath content="M5 17 L14 4 L20 4 L11 17 L20 30 L14 30 Z" fill="#9b5cf6"/>
                    <SVGPath content="M18 17 L27 4 L33 4 L24 17 L33 30 L27 30 Z" fill="#a855f7"/>
                </Pane>
                <Label text="DevPod" style="-fx-text-fill: #090b12; -fx-font-size: 25px; -fx-font-weight: 800;"/>
            </HBox>

            <Region prefHeight="48"/>

            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="11" prefHeight="40"
                      style="-fx-background-color: #b35ff2; -fx-background-radius: 5;">
                    <padding>
                        <Insets left="18" right="14"/>
                    </padding>
                    <Label text="[]" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                    <Label text="Workspaces" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 500;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="11" prefHeight="40">
                    <padding>
                        <Insets left="18" right="14"/>
                    </padding>
                    <Label text="==" style="-fx-text-fill: #535a67; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                    <Label text="Providers" style="-fx-text-fill: #535a67; -fx-font-size: 15px;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="11" prefHeight="40">
                    <padding>
                        <Insets left="18" right="14"/>
                    </padding>
                    <Label text="*" style="-fx-text-fill: #535a67; -fx-font-size: 18px; -fx-font-weight: 800;"/>
                    <Label text="Settings" style="-fx-text-fill: #535a67; -fx-font-size: 15px;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <padding>
                    <Insets left="16"/>
                </padding>
                <Label text="Open sourced by" style="-fx-text-fill: #78859a; -fx-font-size: 13px;"/>
                <Label text="loft" style="-fx-text-fill: #65b7f6; -fx-font-size: 23px; -fx-font-weight: 800;"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <BorderPane style="-fx-background-color: #ffffff;">
            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="106"
                      style="-fx-background-color: #ffffff; -fx-border-color: transparent transparent #dce3ec transparent; -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets left="16" right="11"/>
                    </padding>

                    <Label fx:id="backButton" text="&lt;" onMouseClicked="#showWorkspaces" visible="false" managed="false"
                           style="-fx-text-fill: #111827; -fx-font-size: 21px; -fx-font-weight: 800; -fx-cursor: hand;">
                        <HBox.margin>
                            <Insets right="16"/>
                        </HBox.margin>
                    </Label>

                    <Label fx:id="titleLabel" text="Workspaces"
                           style="-fx-text-fill: #111827; -fx-font-size: 17px; -fx-font-weight: 800;"/>

                    <Button text="+   Create" onAction="#showCreateWorkspace" focusTraversable="false"
                            style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 16 9 16; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700;">
                        <HBox.margin>
                            <Insets left="9"/>
                        </HBox.margin>
                    </Button>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="bell" style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 800;">
                        <HBox.margin>
                            <Insets right="26"/>
                        </HBox.margin>
                    </Label>

                    <Button focusTraversable="false"
                            style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 13 8 13;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="12">
                                <Label text=".PRO"
                                       style="-fx-background-color: #161b26; -fx-background-radius: 2; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: 900; -fx-padding: 2 5 2 5;"/>
                                <Label text="Try DevPod Pro"
                                       style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </top>

            <center>
                <StackPane>
                    <VBox fx:id="workspaceView" style="-fx-background-color: #ffffff;">
                        <padding>
                            <Insets top="35" right="26" bottom="0" left="31"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT">
                            <CheckBox text="Select all" focusTraversable="false"
                                      style="-fx-text-fill: #697386; -fx-font-size: 15px; -fx-font-weight: 700;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox spacing="9" alignment="CENTER_RIGHT">
                                <Button text="Providers (2/2)" focusTraversable="false"
                                        style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 14 9 14; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                <Button text="Status (4/4)" focusTraversable="false"
                                        style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 14 9 14; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                <Button text="Sort by: Recently Used" focusTraversable="false"
                                        style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 15 9 15; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                            </HBox>
                        </HBox>

                        <StackPane VBox.vgrow="ALWAYS">
                            <VBox fx:id="emptyWorkspaceState" alignment="TOP_CENTER" spacing="13">
                                <StackPane.margin>
                                    <Insets top="38"/>
                                </StackPane.margin>
                                <Label text="No workspaces for selection found. Click here to create one"
                                       style="-fx-text-fill: #111827; -fx-font-size: 16px;"/>
                                <Button text="Create Workspace" onAction="#showCreateWorkspace" focusTraversable="false"
                                        style="-fx-background-color: #eef1f5; -fx-background-radius: 5; -fx-padding: 9 14 9 14; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                            </VBox>

                            <VBox fx:id="workspaceList" spacing="10" alignment="TOP_CENTER">
                                <StackPane.margin>
                                    <Insets top="38"/>
                                </StackPane.margin>
                            </VBox>
                        </StackPane>
                    </VBox>

                    <ScrollPane fx:id="createView" visible="false" managed="false" fitToWidth="true"
                                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                style="-fx-background-color: #ffffff; -fx-background: #ffffff;">
                        <VBox spacing="0" style="-fx-background-color: #ffffff;">
                            <padding>
                                <Insets top="30" right="28" bottom="0" left="30"/>
                            </padding>

                            <VBox spacing="12">
                                <Label text="Workspace Name"
                                       style="-fx-text-fill: #1f2430; -fx-font-size: 16px; -fx-font-weight: 800;"/>
                                <TextField fx:id="workspaceNameField" text="my-workspace" prefWidth="430" maxWidth="430"
                                           style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 11 14; -fx-text-fill: #69758b; -fx-font-size: 15px;"/>
                                <Label wrapText="true" maxWidth="560"
                                       text="This is the workspace Name Remotepod will use. This is an optional field and usually&#10;only needed if you have an already existing workspace with the same name."
                                       style="-fx-text-fill: #4e586c; -fx-font-size: 14px;"/>
                                <VBox.margin>
                                    <Insets bottom="24"/>
                                </VBox.margin>
                            </VBox>

                            <BorderPane prefHeight="430"
                                        style="-fx-background-color: #f8fafc; -fx-border-color: #dce3ec; -fx-border-radius: 7; -fx-background-radius: 7;">
                                <center>
                                    <VBox alignment="CENTER" spacing="18">
                                        <Label text="Enter SSH Workspace Source"
                                               style="-fx-text-fill: #1f2430; -fx-font-size: 16px; -fx-font-weight: 800;"/>
                                        <GridPane alignment="CENTER" hgap="14" vgap="12">
                                            <Label text="SSH Server Address" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                                   style="-fx-text-fill: #1f2430; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                            <TextField text="172.17.141.16:22" prefWidth="460" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                                       style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12 15; -fx-text-fill: #768298; -fx-font-size: 15px;"/>

                                            <Label text="User" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                                   style="-fx-text-fill: #1f2430; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                            <TextField text="root" prefWidth="460" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                                       style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12 15; -fx-text-fill: #768298; -fx-font-size: 15px;"/>

                                            <Label text="Password" GridPane.columnIndex="0" GridPane.rowIndex="2"
                                                   style="-fx-text-fill: #1f2430; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                            <PasswordField text="password" prefWidth="460" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                                           style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12 15; -fx-text-fill: #768298; -fx-font-size: 15px;"/>

                                            <Label text="Project Path" GridPane.columnIndex="0" GridPane.rowIndex="3"
                                                   style="-fx-text-fill: #1f2430; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                            <TextField text="/workspace/my-project" prefWidth="460" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                                       style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12 15; -fx-text-fill: #768298; -fx-font-size: 15px;"/>

                                            <Label text="Devcontainer Path" GridPane.columnIndex="0" GridPane.rowIndex="4"
                                                   style="-fx-text-fill: #1f2430; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                            <TextField text=".devcontainer/devcontainer.json" prefWidth="460" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                                       style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12 15; -fx-text-fill: #768298; -fx-font-size: 15px;"/>
                                        </GridPane>
                                        <Label text="RemotePod will connect to the SSH server and use the selected project path as the workspace root."
                                               alignment="CENTER" textAlignment="CENTER" wrapText="false" maxWidth="Infinity" VBox.vgrow="NEVER"
                                               style="-fx-text-fill: #5f6b80; -fx-font-size: 15px;"/>
                                    </VBox>
                                </center>

                                <right>
                                    <VBox prefWidth="204"
                                          style="-fx-background-color: #ffffff; -fx-border-color: transparent transparent transparent #dce3ec; -fx-border-width: 0 0 0 1;">
                                        <VBox alignment="CENTER" prefHeight="86"
                                              style="-fx-border-color: transparent transparent #dce3ec transparent; -fx-border-width: 0 0 1 0;">
                                            <Label text="Or select one of our" style="-fx-text-fill: #7b8498; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                                            <Label text="quickstart examples" style="-fx-text-fill: #7b8498; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                                        </VBox>
                                        <GridPane alignment="TOP_CENTER" hgap="25" vgap="20">
                                            <padding>
                                                <Insets top="25"/>
                                            </padding>
                                            <Label text="PY" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #4778b5; -fx-font-size: 24px; -fx-font-weight: 900;"/>
                                            <Label text="JS" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #70a54a; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                                            <Label text="GO" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #000000; -fx-font-size: 22px; -fx-font-weight: 900; -fx-font-style: italic;"/>
                                            <Label text="R" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #000000; -fx-font-size: 30px; -fx-font-weight: 900;"/>
                                            <Label text="Java" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #d06a18; -fx-font-size: 16px;"/>
                                            <Label text="php" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #000000; -fx-font-size: 26px; -fx-font-weight: 900; -fx-font-style: italic;"/>
                                            <Label text="C++" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #4a72ad; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                                            <Label text="NET" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-text-fill: #9b37e8; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                                        </GridPane>
                                    </VBox>
                                </right>
                            </BorderPane>

                            <GridPane hgap="84" vgap="48">
                                <padding>
                                    <Insets top="28" bottom="26"/>
                                </padding>
                                <VBox spacing="14" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Default IDE *" style="-fx-text-fill: #1f2430; -fx-font-size: 16px; -fx-font-weight: 800;"/>
                                    <TilePane hgap="13" vgap="13" prefColumns="7">
                                        <Label text="None" style="-fx-font-size: 16px; -fx-font-weight: 900;"/>
                                        <Label text="VS" style="-fx-text-fill: #5096e8; -fx-font-size: 30px; -fx-font-weight: 900;"/>
                                        <Label text="VSC" style="-fx-text-fill: #4d91e5; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                                        <Label text="IJ" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="PC" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="PS" style="-fx-background-color: #24104f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="RD" style="-fx-background-color: #2c2e36; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="GO" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="WS" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="RR" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="RM" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="CL" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="DS" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 900; -fx-padding: 6;"/>
                                        <Label text="Jupyter" style="-fx-text-fill: #d17a26; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                                    </TilePane>
                                    <Label text="RemotePod will open this workspace with the selected IDE by default. You can still&#10;change your default IDE later."
                                           style="-fx-text-fill: #5f6b80; -fx-font-size: 15px;"/>
                                </VBox>
                            </GridPane>

                            <HBox alignment="CENTER_LEFT" prefHeight="74"
                                  style="-fx-border-color: #dce3ec transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                                <Button text="Create Workspace" onAction="#createWorkspace" focusTraversable="false"
                                        style="-fx-background-color: #d9a9f6; -fx-background-radius: 5; -fx-padding: 11 19; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </StackPane>
            </center>

            <bottom>
                <HBox alignment="CENTER_LEFT" prefHeight="30"
                      style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                    <padding>
                        <Insets left="24" right="24"/>
                    </padding>
                    <Label text="0.6.15  windows  x86_64" style="-fx-text-fill: #4b5563; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox alignment="CENTER_RIGHT" spacing="24">
                        <Label text="search" style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                        <Label text="star" style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                        <Label text="doc" style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                        <Label text="bug" style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                    </HBox>
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
