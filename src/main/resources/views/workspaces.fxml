<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" style="-fx-background-color: #ffffff;">
    <padding>
        <Insets top="26" right="20" bottom="0" left="22"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Server" style="-fx-text-fill: #697386; -fx-font-size: 12px; -fx-font-weight: 800;"/>
        <ComboBox fx:id="workspaceServerFilterBox" id="workspaceServerFilterBox" focusTraversable="false"
                  prefWidth="220"
                  style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 2 4; -fx-font-size: 12px;"/>
        <Label text="Status" style="-fx-text-fill: #697386; -fx-font-size: 12px; -fx-font-weight: 800;"/>
        <ComboBox fx:id="workspaceStatusFilterBox" id="workspaceStatusFilterBox" focusTraversable="false"
                  prefWidth="140"
                  style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 2 4; -fx-font-size: 12px;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox fx:id="emptyWorkspaceState" id="emptyWorkspaceState" alignment="TOP_CENTER" spacing="13">
            <StackPane.margin>
                <Insets top="38"/>
            </StackPane.margin>
            <Label text="No workspaces for selection found. Click here to create one"
                   style="-fx-text-fill: #111827; -fx-font-size: 14px;"/>
            <Button fx:id="emptyCreateWorkspaceButton" id="emptyCreateWorkspaceButton" text="Create Workspace" focusTraversable="false"
                    style="-fx-background-color: #eef1f5; -fx-background-radius: 5; -fx-padding: 6 10; -fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 700;"/>
        </VBox>

        <ScrollPane fx:id="workspaceListScrollPane" id="workspaceListScrollPane"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox fx:id="workspaceList" id="workspaceList" spacing="10" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="38" bottom="20"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>

        <VBox fx:id="workspaceLoadingState" id="workspaceLoadingState" alignment="CENTER" spacing="12"
              visible="false" managed="false">
            <ProgressIndicator prefWidth="38" prefHeight="38"/>
            <Label text="Loading workspaces..."
                   style="-fx-text-fill: #697386; -fx-font-size: 13px; -fx-font-weight: 700;"/>
        </VBox>
    </StackPane>
</VBox>
