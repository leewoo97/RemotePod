<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           style="-fx-background-color: rgba(17, 24, 39, 0.42);">
    <VBox maxWidth="470" maxHeight="430" spacing="16"
          style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.24), 24, 0.15, 0, 8);">
        <HBox alignment="CENTER_LEFT">
            <Label fx:id="newServerModalTitle" id="newServerModalTitle" text="New SSH Server"
                   style="-fx-text-fill: #111827; -fx-font-size: 19px; -fx-font-weight: 800;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeNewServerModalButton" id="closeNewServerModalButton" text="X" focusTraversable="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #697386; -fx-font-size: 15px; -fx-cursor: hand;"/>
        </HBox>
        <Label text="Enter the connection details. The saved server will appear in the SSH Server dropdown."
               wrapText="true" style="-fx-text-fill: #697386; -fx-font-size: 12px;"/>
        <VBox spacing="7">
            <Label text="SSH Server Address"
                   style="-fx-text-fill: #1f2430; -fx-font-size: 12px; -fx-font-weight: 700;"/>
            <TextField fx:id="newServerAddressField" id="newServerAddressField" promptText="172.17.141.16:22"
                       style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 10; -fx-font-size: 13px;"/>
        </VBox>
        <VBox spacing="7">
            <Label text="User"
                   style="-fx-text-fill: #1f2430; -fx-font-size: 12px; -fx-font-weight: 700;"/>
            <TextField fx:id="newServerUserField" id="newServerUserField" promptText="root"
                       style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 10; -fx-font-size: 13px;"/>
        </VBox>
        <VBox spacing="7">
            <Label text="Password"
                   style="-fx-text-fill: #1f2430; -fx-font-size: 12px; -fx-font-weight: 700;"/>
            <PasswordField fx:id="newServerPasswordField" id="newServerPasswordField" promptText="Password"
                           style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9 10; -fx-font-size: 13px;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <HBox alignment="CENTER_RIGHT" spacing="9">
            <Button fx:id="cancelNewServerButton" id="cancelNewServerButton" text="Cancel" focusTraversable="false"
                    style="-fx-background-color: #ffffff; -fx-border-color: #dce3ec; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 16; -fx-text-fill: #111827; -fx-font-size: 13px; -fx-font-weight: 700;"/>
            <Button fx:id="saveNewServerButton" id="saveNewServerButton" text="Save Server" focusTraversable="false"
                    style="-fx-background-color: #38a169; -fx-background-radius: 6; -fx-padding: 8 16; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700;"/>
        </HBox>
    </VBox>
</StackPane>
